# Copy this file to .env.local and fill in your Supabase project values.
# Find these in: Supabase dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Your deployed URL (used in email confirmation links)
# Leave as http://localhost:3000 for local development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Hugging Face API token for AI symptom analysis (Prompt 3)
# Get yours at: https://huggingface.co/settings/tokens
# Model used: deepseek-ai/DeepSeek-R1-Distill-Llama-8B
HF_TOKEN=hf_your_token_here
